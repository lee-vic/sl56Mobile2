    "@angular/platform-browser-dynamic": "~14.3.0",
    "@angular/router": "~14.3.0",
    "@ionic/angular": "^6.7.5",
    "core-js": "^3.38.1",
    "jquery": "^3.5.1",
    "ng2-pdf-viewer": "^7.0.2",
    "ngx-cookie-service": "^2.4.0",
    "rxjs": "^6.6.7",
    "signalr": "^2.4.1",
    "swiper": "^6.8.4",
    "tslib": "^2.0.0",
    "zone.js": "~0.11.4"
