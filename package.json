  "scripts": {
    "start": "ng serve",
    "build": "ng build --configuration production",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless",
    "lint": "ng lint",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "e2e:ci": "playwright test --reporter=line",
    "e2e:smoke:ci": "playwright test tests/e2e/smoke.spec.ts --reporter=line",
    "e2e:install": "playwright install chromium",
    "verify:phase0": "set NG_CLI_ANALYTICS=false&& npm run build && npm run test:ci"
  },
  "private": true,
